# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- AI providers ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# --- Stripe Billing ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=

# --- Email (Resend) ---
RESEND_API_KEY=

# --- Observability (Sentry) ---
# Public DSN — exposed to the client bundle, safe to commit at deploy time.
NEXT_PUBLIC_SENTRY_DSN=
# Server DSN — usually identical to the public one.
SENTRY_DSN=
# Used by withSentryConfig at build time to upload sourcemaps. Optional.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# --- Operational ---
# Bearer secret for /api/cron/* endpoints. Vercel Cron sends it as
# `Authorization: Bearer <CRON_SECRET>`. Also accepted as ?secret=… for
# manual invocations during incidents.
CRON_SECRET=
# Days to keep audit + finding rows after creation (Privacy Policy).
AUDIT_RETENTION_DAYS=30
# Comma-separated list of emails allowed to access /admin/*.
ADMIN_EMAILS=
# Shared secret with the Supabase Auth Email Hook. Generated once and
# pasted into both Supabase and this env. See DEPLOY.md.
SUPABASE_AUTH_HOOK_SECRET=

# --- App ---
NEXT_PUBLIC_APP_URL=https://lexyflow.com
NEXT_PUBLIC_APP_NAME=LexyFlow
DEFAULT_LOCALE=en
