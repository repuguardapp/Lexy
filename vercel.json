{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm ci --no-audit --no-fund",
  "regions": ["cdg1"],
  "functions": {
    "src/app/api/audit/route.ts":         { "maxDuration": 300, "memory": 1024 },
    "src/app/api/audit/async/route.ts":   { "maxDuration": 60,  "memory": 1024 },
    "src/app/api/checkout/route.ts":      { "maxDuration": 30,  "memory": 512 },
    "src/app/api/cron/purge/route.ts":    { "maxDuration": 60,  "memory": 512 }
  },
  "crons": [
    { "path": "/api/cron/purge", "schedule": "0 4 * * *" }
  ],
  "headers": [
    {
      "source": "/((?!embed/).*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    },
    {
      "source": "/embed/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Content-Security-Policy", "value": "frame-ancestors *" }
      ]
    },
    {
      "source": "/widget.js",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300, must-revalidate" },
        { "key": "Access-Control-Allow-Origin", "value": "*" }
      ]
    }
  ]
}
